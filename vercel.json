{
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": [
    "iad1"
  ],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/api/blog/generate-now/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/blog/process-generation/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/generate-blog/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/autotask-sync/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reports/jobs/sync-tickets/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reports/jobs/sync-time-entries/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reports/jobs/sync-ticket-notes/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reports/jobs/sync-resources/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reports/jobs/compute-lifecycle/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reports/jobs/aggregate-technician/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reports/jobs/aggregate-company/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reports/jobs/compute-health/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reports/jobs/backfill/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reports/jobs/run/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reports/jobs/deliver/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reports/business-review/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reports/business-review/*/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reports/migrate/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/soc-triage/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/process-scheduled-offboards/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/datto-device-sync/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/soc/run/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/soc/bootstrap/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/hr/process/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/hr/submit/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/generate-blog",
      "schedule": "0 8 * * 1,3,5"
    },
    {
      "path": "/api/cron/send-approval-emails",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/publish-scheduled",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/autotask-sync",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/reports/jobs/sync-tickets",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/reports/jobs/sync-time-entries",
      "schedule": "10 */2 * * *"
    },
    {
      "path": "/api/reports/jobs/sync-ticket-notes",
      "schedule": "20 */2 * * *"
    },
    {
      "path": "/api/reports/jobs/sync-resources",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/reports/jobs/compute-lifecycle",
      "schedule": "30 */2 * * *"
    },
    {
      "path": "/api/reports/jobs/aggregate-technician",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/reports/jobs/aggregate-company",
      "schedule": "15 1 * * *"
    },
    {
      "path": "/api/reports/jobs/compute-health",
      "schedule": "0 2 * * 0"
    },
    {
      "path": "/api/reports/jobs/deliver",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/soc-triage",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/datto-device-sync",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/process-scheduled-offboards",
      "schedule": "1 5 * * *"
    }
  ]
}