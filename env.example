# =============================================================================
# Triple Cities Tech — environment variable reference
# =============================================================================
# Copy to .env.local (never commit). Production values live in Vercel.
# All placeholder values below are examples, not real credentials.
# =============================================================================


# --- Core platform ----------------------------------------------------------

# Postgres (Vercel Postgres or compatible). PRISMA_DATABASE_URL points to the
# pooled connection; DATABASE_URL is the direct connection used by migrations.
DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require
PRISMA_DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require

# NextAuth
NEXTAUTH_SECRET=change-me-generate-32-bytes-base64
NEXTAUTH_URL=http://localhost:3000

# Azure AD OAuth (staff login)
AZURE_AD_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_AD_CLIENT_SECRET=replace-me
AZURE_AD_TENANT_ID=00000000-0000-0000-0000-000000000000

# Public URL used by components generating callback / share links
NEXT_PUBLIC_BASE_URL=http://localhost:3000


# --- Secrets used by authenticated API routes -------------------------------

# Gate for /api/migrations/*, /api/test-failures/migrate, /api/soc/migrate,
# /api/autotask/trigger. Send as `Authorization: Bearer <value>` (preferred)
# or legacy `?secret=` query param.
MIGRATION_SECRET=generate-32-bytes-base64

# Vercel sets `Authorization: Bearer $CRON_SECRET` automatically on cron jobs.
# Must match the value Vercel generated for this project.
CRON_SECRET=generate-32-bytes-hex

# Master key for encrypting per-tenant integration credentials at rest
# (see docs/runbooks/CREDENTIALS_MIGRATION.md). 32 raw bytes, base64-encoded.
# Generate with: [Convert]::ToBase64String((1..32 | % { Get-Random -Max 256 }))
ENCRYPTION_MASTER_KEY_V1=generate-32-bytes-base64

# Onboarding portal session signing key (separate from NEXTAUTH_SECRET).
ONBOARDING_SIGNING_KEY=generate-32-bytes-base64


# --- E2E test harness -------------------------------------------------------

# Shared secret for /api/test/auth which mints test sessions for Playwright.
# Leaving this unset disables the endpoint entirely in production.
E2E_TEST_SECRET=


# --- AI -------------------------------------------------------------------

ANTHROPIC_API_KEY=sk-ant-...


# --- Email (Resend) --------------------------------------------------------

RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@triplecitiestech.com
RESEND_FROM_NAME=Triple Cities Tech
NEXT_PUBLIC_CONTACT_EMAIL=info@triplecitiestech.com
NEXT_PUBLIC_QUESTIONNAIRE_EMAIL=info@triplecitiestech.com


# --- Bot protection (Cloudflare Turnstile) ---------------------------------

TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=


# --- Company info (public) -------------------------------------------------

NEXT_PUBLIC_CONTACT_PHONE=(607) 341-7500
NEXT_PUBLIC_COMPANY_NAME=Triple Cities Tech
NEXT_PUBLIC_WEBSITE_URL=https://www.triplecitiestech.com


# =============================================================================
#  Integration credentials
# =============================================================================
# Until the per-tenant `integration_credentials` table is populated (see
# docs/runbooks/CREDENTIALS_MIGRATION.md), all MSP-level integrations read
# credentials from these env vars. Any integration whose value is unset is
# skipped by the compliance collector rather than raising an error.
# =============================================================================


# --- Autotask PSA ----------------------------------------------------------

AUTOTASK_API_USERNAME=
AUTOTASK_API_SECRET=
AUTOTASK_API_INTEGRATION_CODE=
AUTOTASK_API_BASE_URL=https://webservices.autotask.net/ATServicesRest/V1.0


# --- Datto / Kaseya --------------------------------------------------------

DATTO_RMM_API_KEY=
DATTO_RMM_API_SECRET=
DATTO_RMM_API_URL=

DATTO_EDR_API_TOKEN=
DATTO_EDR_API_URL=

DATTO_BCDR_API_KEY=
DATTO_BCDR_API_SECRET=

DATTO_SAAS_API_KEY=
DATTO_SAAS_API_SECRET=


# --- SaaS Alerts -----------------------------------------------------------

# REST API (currently Cloudflare-blocked; webhook ingest is the primary path)
SAAS_ALERTS_API_KEY=
SAAS_ALERTS_PARTNER_ID=

# Partner-generated token echoed back by the SaaS Alerts webhook. Configured
# at manage.saasalerts.com > Settings > API > Webhooks API. Leaving this
# unset disables token verification on /api/compliance/webhooks/saas-alerts.
SAAS_ALERTS_WEBHOOK_TOKEN=


# --- Other MSP tools -------------------------------------------------------

DNSFILTER_API_TOKEN=

DOMOTZ_API_KEY=
DOMOTZ_API_URL=

IT_GLUE_API_KEY=

UBIQUITI_API_KEY=

MYITP_API_KEY=

PAX8_CLIENT_ID=
PAX8_CLIENT_SECRET=


# --- Social / marketing publisher (optional) -------------------------------

# Only needed if blog auto-publishing to social is enabled.
LINKEDIN_ACCESS_TOKEN=
FACEBOOK_PAGE_ACCESS_TOKEN=
TWITTER_BEARER_TOKEN=
