# ============================================
# DATABASE (Prisma Postgres)
# ============================================
# Get these from: Prisma Dashboard > Your Database > Connection Strings
# DATABASE_URL: Direct connection for migrations
# PRISMA_DATABASE_URL: Accelerate connection for application (with connection pooling)
DATABASE_URL=
PRISMA_DATABASE_URL=

# ============================================
# DATABASE SETUP (ONE-TIME USE)
# ============================================
# Secret token for running database migrations via API
# Generate with: openssl rand -base64 32
# DELETE THIS VARIABLE AND /api/setup/migrate AFTER FIRST DEPLOYMENT
MIGRATION_SECRET=

# ============================================
# ANTHROPIC AI (Claude API for Project Generation)
# ============================================
# Get API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ============================================
# NEXTAUTH (Microsoft OAuth for Staff Login)
# ============================================
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://www.triplecitiestech.com

# Microsoft Azure AD OAuth
# Create at: https://portal.azure.com > App registrations > New registration
# Redirect URI: https://www.triplecitiestech.com/api/auth/callback/azure-ad
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ============================================
# CFO DASHBOARD ACCESS CONTROL
# ============================================
# The CFO dashboard (/admin/cfo) is restricted. A staff user gains access if
# EITHER they hold the `view_cfo_dashboard` permission (granted to SUPER_ADMIN
# by default, or per-user via permission overrides) OR they belong to one of
# the Entra groups listed below.
# Comma-separated list of accounting/finance Entra security group object IDs.
# Leave blank to disable the group path (allowlist still works).
# Requires the GroupMember.Read.All Application permission (+ admin consent) on
# the AZURE_AD app registration so the app-only Graph membership check can run.
CFO_DASHBOARD_ENTRA_GROUP_IDS=

# CFO dashboard data sources.
# Sequence (banking) — required for the live cash-flow analytics.
SEQUENCE_API_TOKEN=
# QuickBooks Online app (Intuit developer portal). QB_ENV = production | sandbox.
# QB_REDIRECT_URI defaults to ${NEXT_PUBLIC_BASE_URL}/api/admin/cfo/qb/callback.
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_ENV=production
QB_REDIRECT_URI=
# 32-byte base64 key used to encrypt QuickBooks tokens (and other secrets) at rest.
# Generate (PowerShell): [Convert]::ToBase64String((1..32 | % { Get-Random -Max 256 }))
ENCRYPTION_MASTER_KEY_V1=

# ============================================
# SESSION SIGNING KEY (for customer portal cookies)
# ============================================
# Generate with: openssl rand -base64 32
ONBOARDING_SIGNING_KEY=

# ============================================
# EMAIL & SPAM PROTECTION
# ============================================
# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key_here

# Cloudflare Turnstile (Spam Protection)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Contact Form Configuration
NEXT_PUBLIC_CONTACT_EMAIL=your_email@example.com

# ============================================
# BLOG SYSTEM
# ============================================
# Blog cron job secret (protect automated endpoints)
# Generate with: openssl rand -base64 32
BLOG_CRON_SECRET=

# Blog approval email recipient
APPROVAL_EMAIL=kurtis@triplecitiestech.com

# Base URL for links in emails
NEXT_PUBLIC_BASE_URL=https://www.triplecitiestech.com

# Social Media API Tokens
# Facebook Page (get from: https://developers.facebook.com)
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# Instagram Business Account (requires Facebook Business account)
# Get from: https://developers.facebook.com/apps
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# LinkedIn Company Page
# Get from: https://www.linkedin.com/developers/apps
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=

# Twitter/X (optional)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ============================================
# AUTOTASK PSA INTEGRATION
# ============================================
# API credentials from Autotask Admin > Resources > API Users
AUTOTASK_API_USERNAME=
AUTOTASK_API_SECRET=
AUTOTASK_API_INTEGRATION_CODE=
# Zone-specific base URL (check your Autotask zone)
# Example: https://webservices6.autotask.net/ATServicesRest
AUTOTASK_API_BASE_URL=
# Secret for manually triggering sync (generate with: openssl rand -base64 32)
AUTOTASK_SYNC_SECRET=

# MCP connector gated CONFIG writes (stage → human approval → execute).
# Writes stay disabled until this is exactly 'true'; read tools are unaffected.
CONNECTOR_CONFIG_WRITES_ENABLED=false
# Minutes before an unexecuted staged write expires (default 60)
CONNECTOR_STAGED_WRITE_TTL_MINUTES=60

# MCP connector UniFi writes (BOTH tiers: direct device/client actions AND
# staged config changes). Reads are unaffected. Must be exactly 'true'.
CONNECTOR_UNIFI_WRITES_ENABLED=false

# --- MCP connector auth (OAuth authorization server) ---
# Which authorization server protects the connector: 'workos' (default) or
# 'entra' (Microsoft Entra / Azure AD). Switching is env-only — no redeploy of
# code. Full setup: docs/runbooks/CONNECTOR_AUTH_ENTRA.md
CONNECTOR_AUTH_PROVIDER=workos
# Canonical resource id for the connector — RFC 9728 'resource' and the RFC 8707
# resource indicator Claude sends. Set to the MCP endpoint URL, e.g.
# https://www.triplecitiestech.com/api/connector/mcp
MCP_RESOURCE_URL=
#
# provider=workos (WorkOS AuthKit): AuthKit domain (issuer; JWKS at
# <domain>/oauth2/jwks; token aud = MCP_RESOURCE_URL) + an API key used only to
# resolve a user's email by id when the token has no email claim.
AUTHKIT_DOMAIN=
WORKOS_API_KEY=
#
# provider=entra (Microsoft Entra): tenant id + the token audience we accept.
# IMPORTANT: Entra v2 access tokens carry the app's CLIENT ID (a GUID) as `aud`,
# NOT the Application ID URI — set CONNECTOR_ENTRA_AUDIENCE to that client id.
CONNECTOR_ENTRA_TENANT_ID=
CONNECTOR_ENTRA_AUDIENCE=
# (optional) issuer override for sovereign clouds (default global v2 issuer):
# CONNECTOR_ENTRA_ISSUER=
# (optional) space-separated scopes to advertise so Claude requests the right one:
# CONNECTOR_ENTRA_SCOPES=

# MCP connector HR Employee-Relations writes (hr_er_log_append, hr_file_document)
# to TCT's OWN HumanResources SharePoint site. Direct writes, audit-logged.
# Kill switch — the tools stay dormant unless this is exactly 'true'.
CONNECTOR_HR_WRITES_ENABLED=false
# Dedicated, least-privilege Entra app for the HR site. Application permission
# Sites.Selected, granted the 'write' role on ONLY the HumanResources site via
# POST /sites/{siteId}/permissions (Sites.Selected + admin consent alone grants
# no site access). Do NOT reuse the AZURE_AD staff-SSO app for this.
HR_RECORDS_TENANT_ID=
HR_RECORDS_CLIENT_ID=
HR_RECORDS_CLIENT_SECRET=
# (optional) Override the live-verified workbook location if the file is moved.
# HR_ER_DRIVE_ID=
# HR_ER_ITEM_ID=
# (optional) Worksheet tab holding the log table (default "Log").
# HR_ER_LOG_WORKSHEET=Log

# ============================================
# EXCHANGE ONLINE AUTOMATION (offboarding mailbox conversion)
# Setup: docs/runbooks/EXO_AUTOMATION_ENABLEMENT.md
# ============================================
# Kill switch — must be exactly 'true' or every tenant degrades to [MANUAL]
EXO_AUTOMATION_ENABLED=false
# Azure Automation webhook URL (contains its token — treat as a secret)
EXO_AUTOMATION_WEBHOOK_URL=
# HMAC secret signing outbound job payloads (= Automation var TctExoDispatchSecret)
EXO_DISPATCH_SECRET=
# HMAC secret verifying runner callbacks (= Automation var TctExoCallbackSecret)
EXO_CALLBACK_SECRET=
# Minutes before the reconcile cron times out a job with no callback (default 45)
EXO_JOB_TIMEOUT_MINUTES=45

# ============================================
# UBIQUITI UNIFI (Site Manager + Cloud Connector Proxy)
# ============================================
# API key from unifi.ui.com > Settings > API Keys. Used by src/lib/ubiquiti.ts
# (aggregate reads) and src/lib/ubiquiti-proxy.ts (per-console Integration API
# via the Cloud Connector Proxy — consoles need Network app >= 10.1.84).
UBIQUITI_API_KEY=
# Cloud API base URL (default https://api.ui.com)
UBIQUITI_API_URL=

# ============================================
# BROWSERBASE (Remote Browser Testing)
# ============================================
# Get from: https://www.browserbase.com/settings
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# Base URL for Playwright tests (set to Vercel preview URL for remote testing)
# PLAYWRIGHT_BASE_URL=https://your-preview.vercel.app

# ============================================
# LEGACY (Will be migrated to database)
# ============================================
# Customer Onboarding Portal Passwords
# These will be moved to the database and managed via admin UI
ONBOARDING_PASSWORD_ECOSPECT=your_secure_password_here
ONBOARDING_PASSWORD_ALL_SPEC_FINISHING=your_secure_password_here

# ============================================
# DATTO RMM (Device Management & SOC Integration)
# ============================================
# API credentials from Datto RMM > Setup > API
DATTO_RMM_API_KEY=
DATTO_RMM_API_SECRET=
# API URL (zone-specific, e.g. https://concord-api.centrastage.net)
DATTO_RMM_API_URL=

# ============================================
# PAX8 (Cloud Marketplace — License Auto-Procurement)
# ============================================
# OAuth2 credentials from Pax8 Partner Portal > Settings > Developer
PAX8_CLIENT_ID=
PAX8_CLIENT_SECRET=

# ============================================
# DATTO EDR (Endpoint Detection & Response)
# ============================================
# API token from: Datto EDR > Admin > Users & Tokens
# Instance URL: https://<instance>.infocyte.com/api
# Visit https://<instance>.infocyte.com/explorer/#/ to see available endpoints
DATTO_EDR_API_TOKEN=
DATTO_EDR_API_URL=https://triple5695.infocyte.com/api

# ============================================
# DNSFILTER (DNS Security)
# ============================================
# API token from: DNSFilter Dashboard > Account > API Keys
# Requires Professional subscription ($50/mo minimum)
# Docs: https://api.dnsfilter.com/docs
# Rate limit: 2000 requests per 5 minutes per organization
DNSFILTER_API_TOKEN=
# API URL (optional, defaults to https://api.dnsfilter.com/v1)
# DNSFILTER_API_URL=

# ============================================
# ROCKETCYBER (Kaseya — Managed SOC)
# ============================================
# Customer API token from: RocketCyber portal > Provider Settings > RocketCyber API
# Used by the SOC Analyst to pull full incident/detection detail (process, path,
# command line, hash, threat name) that the Autotask ticket body leaves UNDEFINED.
# Docs: https://api-doc.rocketcyber.com/
ROCKETCYBER_API_TOKEN=
# API URL (optional, defaults to the US region below). EU region: https://api-eu.rocketcyber.com/v3
ROCKETCYBER_API_URL=https://api-us.rocketcyber.com/v3

# ============================================
# SOC REAL-TIME INGEST WEBHOOK
# ============================================
# Shared secret for the real-time SOC ingest endpoint (/api/soc/ingest).
# Configure an Autotask workflow rule (Extension Callout) on the Security
# Monitoring Alert queue to POST the new ticket ID here with this secret in the
# Authorization: Bearer header (or ?secret= / x-soc-secret). Falls back to
# MIGRATION_SECRET / CRON_SECRET if unset. Generate: openssl rand -base64 32
SOC_INGEST_SECRET=

# ============================================
# THREAD (customer chat — Magic Agents)
# ============================================
# URL key for Thread's Automation URL webhook
# (/api/integrations/thread/webhook) and programmatic form-link creation
# (/api/forms/links). Thread's Automation URL feature POSTs a bare JSON body
# and CANNOT send auth headers or signatures
# (https://docs.getthread.com/article/7vxm10v3zj-magic-agents-automation-url),
# so the key rides in the URL and the full URL is the credential. Paste one
# URL per Magic Intent into Thread, e.g.:
#   https://www.triplecitiestech.com/api/integrations/thread/webhook?key=<value>&type=onboarding
#   https://www.triplecitiestech.com/api/integrations/thread/webhook?key=<value>&type=offboarding
# FAIL-CLOSED: when unset, the webhook rejects ALL requests (401).
# Generate (PowerShell): [Convert]::ToBase64String((1..32 | % { Get-Random -Max 256 })) -replace '[/+=]',''
THREAD_AUTOMATION_KEY=

# ============================================
# DATTO BCDR (Backup & Disaster Recovery)
# ============================================
# Public/Secret key pair from: Datto Partner Portal > Admin > Integrations > API Keys
# IMPORTANT: Leave "Select Vendor" dropdown BLANK when creating keys
# Uses HTTP Basic Auth (public:secret base64-encoded)
DATTO_BCDR_PUBLIC_KEY=
DATTO_BCDR_PRIVATE_KEY=
# API URL (optional, defaults to https://api.datto.com/v1)
# DATTO_BCDR_API_URL=

# ============================================
# SAAS ALERTS (Kaseya — SaaS Security Monitoring)
# ============================================
# Two distinct surfaces:
#   1. Webhook receiver  (primary) — Kaseya pushes events to
#      /api/compliance/webhooks/saas-alerts. Configure at
#      manage.saasalerts.com > Settings > API > Webhooks API.
#   2. External Partner API (REST, fallback) — on Google Cloud Functions,
#      NOT the Cloudflare-blocked manage.saasalerts.com/api host.
#      Swagger: https://app.swaggerhub.com/apis/SaaS_Alerts/functions/0.20.0
#
# Webhook receiver token (echoed back by Kaseya on every delivery)
SAAS_ALERTS_WEBHOOK_TOKEN=
# Webhook management API key (for the /api/admin/compliance/saas-alerts/* routes
# that subscribe new domains). From manage.saasalerts.com > Settings > API >
# Webhook API > Show Api Key.
SAAS_ALERTS_WEBHOOKS_API_KEY=
# (optional) Webhook management base URL — defaults to the Kaseya prod host
# SAAS_ALERTS_WEBHOOKS_BASE_URL=
#
# External Partner API credentials — `api_key` header (required):
#   from manage.saasalerts.com > Settings > API > Show Api Key,
#   or via GET /tools/apiKey on the partner API
SAAS_ALERTS_API_KEY=
#
# `idtoken` header — short-lived Firebase Auth JWT (1h TTL). Two ways to
# supply it. Use ONE (refresh token preferred):
#
#   (a) Refresh token (production — auto-refreshes hourly inside the client).
#       The 200-ish-char value lives in the portal browser session at:
#         DevTools > Application > IndexedDB > firebaseLocalStorageDb >
#           firebaseLocalStorage > firebase:authUser:... >
#           stsTokenManager.refreshToken
#       (NOT in localStorage — Firebase v9 SDK uses IndexedDB.)
SAAS_ALERTS_REFRESH_TOKEN=
#
#   (b) Static idtoken — paste the live idtoken request header from any
#       cloudfunctions.net XHR in the portal. Will expire in ≤1h. Only set
#       this for one-off smoke tests; leave blank in production.
SAAS_ALERTS_ID_TOKEN=
#
# (optional) Firebase Web API key for the SaaS Alerts project. NOT a secret —
# it's embedded in the portal SPA — but parameterised here in case Kaseya
# rotates the project. Defaults to the public value if omitted.
# SAAS_ALERTS_FIREBASE_API_KEY=
#
# (optional) Referer header sent with the refresh-token exchange. Kaseya's
# Firebase Web API key has HTTP-referrer restrictions; server-to-server
# requests get blocked unless we spoof a permitted origin. Defaults to
# https://manage.saasalerts.com/ which the portal SPA also uses.
# SAAS_ALERTS_REFRESH_REFERER=https://manage.saasalerts.com/
#
# (optional) Partner ID — used to scope filtered event queries. Not used for auth.
SAAS_ALERTS_PARTNER_ID=
# (optional) Base URL override. Default points to the production Cloud Functions
# host. Alternate envs:
#   QA:  https://us-central1-saas-alerts-qa.cloudfunctions.net/reportApi/api/v1
#   Dev: https://us-central1-saas-alerts-dev.cloudfunctions.net/reportApi/api/v1
# SAAS_ALERTS_API_URL=https://us-central1-the-byway-248217.cloudfunctions.net/reportApi/api/v1

# ============================================
# CRON JOBS
# ============================================
# Secret for authenticating Vercel cron job requests
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ============================================
# GUSTO (PTO / Payroll integration)
# ============================================
# OAuth 2.0 credentials from Gusto Developer Portal
# Demo env: https://dev.gusto.com — create an app, copy client ID/secret
# Redirect URI must be added in the Gusto app settings exactly as:
#   https://www.triplecitiestech.com/api/admin/integrations/gusto/callback
#   https://<preview-branch>-triplecitiestech.vercel.app/api/admin/integrations/gusto/callback
#   http://localhost:3000/api/admin/integrations/gusto/callback
GUSTO_ENV=demo
GUSTO_CLIENT_ID=
GUSTO_CLIENT_SECRET=
GUSTO_OAUTH_REDIRECT_URI=https://www.triplecitiestech.com/api/admin/integrations/gusto/callback

# ============================================
# PTO / Time-off system
# ============================================
# Shared mailbox OR M365 group email where approved PTO events are written.
# A shared mailbox requires creating one in M365 admin center.
# A group uses the calendar attached to an M365 Group (no mailbox needed).
#
# IMPORTANT — Azure AD application permissions required (with admin consent):
#   PTO_CALENDAR_TYPE=user  →  Calendars.ReadWrite       (and the address must be a real mailbox)
#   PTO_CALENDAR_TYPE=group →  Group.ReadWrite.All       (Calendars.ReadWrite is NOT enough for groups)
# Plus: User.Read.All, Group.Read.All for lookups.
# A 403 ErrorAccessDenied on /groups/{id}/events almost always means
# Group.ReadWrite.All is missing or hasn't been admin-consented.
PTO_CALENDAR_MAILBOX=HumanResources@triplecitiestech.com
# 'user' (default) = /users/{mailbox}/events, 'group' = /groups/{mail}/events
PTO_CALENDAR_TYPE=group
# From address + display name for PTO emails
PTO_FROM_EMAIL=HumanResources@triplecitiestech.com
PTO_FROM_NAME=Triple Cities Tech HR
# HR M365 group — members receive approval notifications
PTO_HR_GROUP_NAME=HumanResources
PTO_HR_GROUP_MAIL=HumanResources@triplecitiestech.com
# Fallback approver (always notified)
PTO_APPROVER_FALLBACK_EMAIL=kurtis@triplecitiestech.com
# Default daily hours for full-day PTO (default 8)
# PTO_DEFAULT_DAILY_HOURS=8

# (Exchange Online automation env vars are defined in the EXCHANGE ONLINE
# AUTOMATION block above — docs/runbooks/EXO_AUTOMATION_ENABLEMENT.md)
