// Prisma Schema for Triple Cities Tech Project Status Platform
// Supports AI-generated project plans with customer-facing status pages

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// STAFF USERS & AUTHENTICATION
// ============================================

model StaffUser {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String
  role      StaffRole @default(TECHNICIAN)
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Per-user permission overrides (beyond base role)
  // JSON: { "granted": ["permission1"], "revoked": ["permission2"] }
  permissionOverrides Json?

  // Autotask integration
  autotaskResourceId String? // Cached Autotask Resource ID for SSO matching

  // Relations
  blogPosts BlogPost[]

  @@map("staff_users")
}

enum StaffRole {
  SUPER_ADMIN    // Full control: manage staff roles, system settings, delete anything, billing
  ADMIN          // Admin access: manage projects, companies, contacts, blog, SOC, marketing
  BILLING_ADMIN  // Billing focus: view projects/companies, manage billing, view reports
  TECHNICIAN     // Field tech: view assigned projects/tickets, add notes, update task status
}

// ============================================
// NEXTAUTH TABLES (Required for authentication)
// ============================================

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// COMPANIES & PROJECTS
// ============================================

model Company {
  id             String   @id @default(uuid())
  slug           String   @unique // URL-friendly: 'acme-manufacturing'
  displayName    String // 'Acme Manufacturing'
  primaryContact String?
  contactTitle   String?
  contactEmail   String?
  passwordHash   String // bcrypt hash for customer portal access
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Autotask integration
  autotaskCompanyId     String?  @unique // Autotask Company/Account ID
  autotaskLastSync      DateTime? // Last successful sync timestamp
  companyClassification String?  // Autotask classification (e.g., "Platinum Managed Service")
  // Only companies with classification "Platinum Managed Service" get SLA reporting

  // M365 per-tenant app registration credentials (added via add_m365_tenant_credentials.sql)
  m365TenantId          String?   @map("m365_tenant_id")
  m365ClientId          String?   @map("m365_client_id")
  m365ClientSecret      String?   @map("m365_client_secret")
  m365VerifiedAt        DateTime? @map("m365_verified_at")
  m365SetupStatus       String?   @default("not_configured") @map("m365_setup_status")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")

  // Compliance portal visibility toggle
  compliancePortalEnabled Boolean @default(false) @map("compliancePortalEnabled")

  // Relations
  projects        Project[]
  contacts        CompanyContact[]
  tickets         Ticket[]
  businessReviews BusinessReview[]
  hrRequests      HrRequest[]

  @@map("companies")
}

enum PhoneType {
  MOBILE
  WORK
}

enum CustomerRole {
  CLIENT_MANAGER  // Full access: projects, tickets, billing, can manage other contacts
  CLIENT_USER     // Standard access: view projects, submit/view tickets
  CLIENT_VIEWER   // Read-only access: view projects and tickets only
}

enum InviteStatus {
  NOT_INVITED
  INVITED       // Email sent, pending acceptance
  ACCEPTED      // User has logged in at least once
  DECLINED      // User declined or bounced
}

model CompanyContact {
  id        String     @id @default(uuid())
  companyId String
  name      String
  email     String
  title     String?
  phone     String?
  phoneType PhoneType?
  isPrimary Boolean    @default(false)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Customer portal access
  customerRole   CustomerRole @default(CLIENT_USER)
  inviteStatus   InviteStatus @default(NOT_INVITED)
  invitedAt      DateTime?
  inviteAcceptedAt DateTime?
  lastPortalLogin DateTime?

  // Autotask integration
  autotaskContactId String? @unique // Autotask Contact ID

  // Relations
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, email])
  @@map("company_contacts")
}

model Project {
  id                String        @id @default(uuid())
  companyId         String
  projectType       ProjectType
  title             String // 'Microsoft 365 Migration & Security'
  slug              String        @unique // 'acme-manufacturing-m365-migration'
  currentPhaseId    String? // Track which phase they're on
  status            ProjectStatus @default(ACTIVE)
  estimatedDuration String? // '30 days', '6 weeks'
  startedAt         DateTime?
  completedAt       DateTime?
  createdBy         String // Staff email
  lastModifiedBy    String // Staff email
  aiGenerated       Boolean @default(false)
  generationPrompt  String? @db.Text // Original prompt sent to Claude API
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Autotask integration
  autotaskProjectId String? @unique // Autotask Project ID
  autotaskLastSync  DateTime? // Last successful sync timestamp

  // Relations
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  phases    Phase[]
  auditLogs AuditLog[]

  @@map("projects")
}

enum ProjectType {
  ONBOARDING // New client onboarding
  M365_MIGRATION // Microsoft 365 migration
  FORTRESS // TCT Fortress security implementation
  CUSTOM // Custom project
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}

// ============================================
// PHASES & TASKS
// ============================================

model Phase {
  id            String      @id @default(uuid())
  projectId     String
  title         String
  description   String?     @db.Text
  status        PhaseStatus @default(NOT_STARTED)
  owner         PhaseOwner?
  estimatedDays Int?
  scheduledDate DateTime?
  completedDate DateTime?
  orderIndex    Int // For sorting (1, 2, 3...)
  customerNotes String?     @db.Text // Visible to customer
  internalNotes String?     @db.Text // STAFF ONLY - hidden from customer
  nextAction    String?     @db.Text

  // New fields for enhanced phase management
  isVisibleToCustomer Boolean @default(true)

  // Autotask integration
  autotaskPhaseId String? @unique // Autotask Phase/Task ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       PhaseTask[]
  auditLogs   AuditLog[]
  comments    Comment[]
  assignments Assignment[]

  @@map("phases")
}

enum PhaseStatus {
  NOT_STARTED
  SCHEDULED
  WAITING_ON_CUSTOMER
  IN_PROGRESS
  REQUIRES_CUSTOMER_COORDINATION
  DISCUSSED
  COMPLETE
}

enum PhaseOwner {
  TCT
  CUSTOMER
  BOTH
}

enum TaskStatus {
  NOT_STARTED
  ASSIGNED
  WORK_IN_PROGRESS
  WAITING_ON_VENDOR
  WAITING_ON_CLIENT
  NEEDS_REVIEW
  STUCK
  INFORMATION_RECEIVED
  REVIEWED_AND_DONE
  ITG_DOCUMENTED
  NOT_APPLICABLE
  CUSTOMER_NOTE_ADDED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model PhaseTask {
  id          String    @id @default(uuid())
  phaseId     String
  taskText    String    @db.Text
  completed   Boolean   @default(false)
  completedBy String? // Staff email
  completedAt DateTime?
  notes       String?   @db.Text
  orderIndex  Int // For sorting

  // New fields for enhanced task management
  status              TaskStatus   @default(NOT_STARTED)
  isVisibleToCustomer Boolean      @default(true)
  assignedTo          String? // Primary assignee email
  assignedToName      String? // Primary assignee display name
  dueDate             DateTime?
  priority            Priority     @default(MEDIUM)
  responsibleParty    PhaseOwner? // TCT, CUSTOMER, or BOTH

  // Sub-tasks support (up to 3 levels deep)
  parentTaskId String? // null for top-level tasks

  // Autotask integration
  autotaskTaskId String? @unique // Autotask Task/Ticket ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  phase       Phase        @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  parent      PhaseTask?   @relation("SubTasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subTasks    PhaseTask[]  @relation("SubTasks")
  comments    Comment[]
  assignments Assignment[]

  @@map("phase_tasks")
}

// ============================================
// COMMENTS SYSTEM
// ============================================

model Comment {
  id          String   @id @default(uuid())
  phaseId     String?
  taskId      String?
  content     String   @db.Text
  isInternal  Boolean  @default(false) // true = staff only, false = customer can see
  authorEmail String // Staff email or "customer"
  authorName  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  phase Phase?     @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  task  PhaseTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("comments")
}

// ============================================
// ASSIGNMENTS & NOTIFICATIONS
// ============================================

enum NotificationType {
  ASSIGNMENT
  COMMENT
  STATUS_CHANGE
  MENTION
}

model Assignment {
  id            String   @id @default(uuid())
  phaseId       String?
  taskId        String?
  assigneeEmail String // M365 user email
  assigneeName  String
  assignedBy    String // Staff email who made assignment
  assignedAt    DateTime @default(now())

  // Relations
  phase Phase?     @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  task  PhaseTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([phaseId, assigneeEmail])
  @@unique([taskId, assigneeEmail])
  @@map("assignments")
}

model Notification {
  id             String           @id @default(uuid())
  recipientEmail String
  type           NotificationType
  entityType     String // 'phase', 'task', 'comment'
  entityId       String
  title          String
  message        String           @db.Text
  isRead         Boolean          @default(false)
  linkUrl        String?
  createdAt      DateTime         @default(now())

  @@map("notifications")
}

// ============================================
// AUDIT LOGGING
// ============================================

model AuditLog {
  id         String      @id @default(uuid())
  projectId  String
  phaseId    String?
  staffEmail String
  staffName  String?
  staffRole  StaffRole?
  actionType AuditAction
  entityType String // 'project', 'phase', 'task'
  changes    Json? // { before: {...}, after: {...} }
  notes      String?     @db.Text
  createdAt  DateTime    @default(now())

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase   Phase?  @relation(fields: [phaseId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

enum AuditAction {
  CREATED
  UPDATED
  STATUS_CHANGED
  DELETED
  AI_GENERATED
  TEMPLATE_APPLIED
  PASSWORD_CHANGED
}

// ============================================
// PROJECT TEMPLATES
// ============================================

model ProjectTemplate {
  id          String      @id @default(uuid())
  name        String // 'M365 Migration', 'TCT Fortress Onboarding'
  description String?     @db.Text
  projectType ProjectType
  phasesJson  Json // Pre-defined phase structure
  createdBy   String // Staff email - no foreign key to avoid production DB issues
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("project_templates")
}

// ============================================
// AUTOTASK INTEGRATION
// ============================================

model AutotaskSyncLog {
  id          String   @id @default(uuid())
  syncType    String // 'full', 'incremental'
  status      String // 'success', 'partial', 'failed'
  companiesCreated  Int @default(0)
  companiesUpdated  Int @default(0)
  projectsCreated   Int @default(0)
  projectsUpdated   Int @default(0)
  contactsCreated   Int @default(0)
  contactsUpdated   Int @default(0)
  tasksCreated      Int @default(0)
  tasksUpdated      Int @default(0)
  errors      String? @db.Text // JSON array of error messages
  durationMs  Int? // How long the sync took
  startedAt   DateTime @default(now())
  completedAt DateTime?

  @@map("autotask_sync_logs")
  @@index([startedAt])
}

// ============================================
// API USAGE & PLATFORM MONITORING
// ============================================

model ApiUsageLog {
  id            String   @id @default(uuid())
  provider      String   // 'anthropic', 'resend', 'autotask', 'vercel'
  feature       String   // 'blog-generation', 'campaign-gen', 'ai-chat', 'ai-support-review', 'blog-editor'
  model         String?  // 'claude-sonnet-4-6', etc.
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  totalTokens   Int      @default(0)
  costCents     Float    @default(0) // Estimated cost in cents
  durationMs    Int?
  statusCode    Int?     // HTTP status code
  error         String?  @db.Text
  metadata      Json?    // Additional context (prompt length, etc.)
  createdAt     DateTime @default(now())

  @@map("api_usage_logs")
  @@index([provider, createdAt])
  @@index([feature, createdAt])
  @@index([createdAt])
}

model PlatformThreshold {
  id            String   @id @default(uuid())
  metricKey     String   @unique // 'anthropic_tokens_monthly', 'db_rows_total', 'resend_emails_monthly', etc.
  displayName   String
  currentValue  Float    @default(0)
  limitValue    Float    // The threshold limit
  unit          String   // 'tokens', 'rows', 'emails', 'GB', 'requests'
  provider      String   // 'anthropic', 'vercel-postgres', 'resend', 'autotask'
  lastCheckedAt DateTime @default(now())
  lastAlertedAt DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("platform_thresholds")
}

model SystemHealthSnapshot {
  id            String   @id @default(uuid())
  dbLatencyMs   Int
  dbStatus      String   // 'healthy', 'degraded', 'down'
  overallStatus String   // 'healthy', 'degraded', 'down'
  servicesUp    Int      @default(0)
  servicesTotal Int      @default(0)
  errorCount24h Int      @default(0)
  createdAt     DateTime @default(now())

  @@map("system_health_snapshots")
  @@index([createdAt])
}

// ============================================
// BLOG SYSTEM
// ============================================

model BlogPost {
  id              String        @id @default(uuid())
  slug            String        @unique
  title           String
  excerpt         String        @db.Text
  content         String        @db.Text
  featuredImage   String?

  // AI Generation metadata
  sourceUrls      String[]      // URLs used for inspiration
  aiPrompt        String?       @db.Text
  aiModel         String?       // "claude-sonnet-4-5-20250929"

  // Publishing status
  status          BlogStatus    @default(DRAFT)
  scheduledFor    DateTime?
  publishedAt     DateTime?

  // Visibility — controls who can see this post
  visibility      ContentVisibility @default(PUBLIC)
  accessToken     String?           @unique // Magic link token for restricted posts

  // SEO
  metaTitle       String?
  metaDescription String?       @db.Text
  keywords        String[]

  // Social media
  facebookPostId  String?
  instagramPostId String?
  linkedinPostId  String?
  twitterPostId   String?

  // Approval workflow
  sentForApproval DateTime?
  approvedAt      DateTime?
  approvedBy      String?       // Email of approver
  approvalToken   String?       @unique
  rejectionReason String?       @db.Text
  revisionCount   Int           @default(0)

  // Analytics
  views           Int           @default(0)
  shares          Int           @default(0)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Campaign link (if this post was created via a communication campaign)
  campaignId      String?

  // Relations
  author          StaffUser?    @relation(fields: [authorId], references: [id])
  authorId        String?
  category        BlogCategory? @relation(fields: [categoryId], references: [id])
  categoryId      String?
  tags            BlogTag[]

  @@map("blog_posts")
  @@index([status, publishedAt])
  @@index([slug])
  @@index([approvalToken])
}

enum BlogStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

model BlogCategory {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?    @db.Text
  posts       BlogPost[]

  @@map("blog_categories")
}

model BlogTag {
  id    String     @id @default(uuid())
  name  String     @unique
  slug  String     @unique
  posts BlogPost[]

  @@map("blog_tags")
}

model ContentSource {
  id              String   @id @default(uuid())
  name            String
  url             String
  rssFeedUrl      String?
  apiEndpoint     String?
  isActive        Boolean  @default(true)
  lastFetched     DateTime?
  fetchFrequency  String   @default("daily") // "hourly", "daily", "weekly"

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("content_sources")
}

model SocialMediaPost {
  id          String   @id @default(uuid())
  blogPostId  String
  platform    String   // "facebook", "instagram", "linkedin", "twitter"
  platformId  String?  // Platform-specific post ID
  content     String   @db.Text
  imageUrl    String?
  status      String   @default("pending") // "pending", "posted", "failed"
  postedAt    DateTime?
  error       String?  @db.Text

  createdAt   DateTime @default(now())

  @@map("social_media_posts")
  @@index([blogPostId, platform])
}

model BlogSettings {
  id         String   @id @default(uuid())
  key        String   @unique
  value      String   @db.Text
  updatedAt  DateTime @updatedAt
  updatedBy  String?

  @@map("blog_settings")
}

// ============================================
// SALES & MARKETING SYSTEM
// ============================================

/// Provider type for audience sources — extensible for future integrations
enum AudienceProviderType {
  AUTOTASK
  HUBSPOT
  CSV_IMPORT
  MANUAL
}

/// Configured audience source (e.g., "Our Autotask Instance", "HubSpot CRM")
model AudienceSource {
  id           String               @id @default(uuid())
  name         String               // "Autotask PSA", "HubSpot CRM"
  providerType AudienceProviderType
  config       Json?                // Provider-specific config (API keys, endpoints, etc.)
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  // Relations
  audiences Audience[]

  @@map("audience_sources")
}

/// A named, reusable audience segment with filter criteria
model Audience {
  id             String               @id @default(uuid())
  name           String               // "All Active Customers", "Enterprise Clients"
  description    String?              @db.Text
  sourceId       String
  providerType   AudienceProviderType // Denormalized for quick filtering
  filterCriteria Json                 // Provider-specific filter (e.g., { companyIds: [...] } or { groupId: "..." })
  recipientCount Int                  @default(0) // Cached count
  isActive       Boolean              @default(true)
  createdBy      String               // Staff email
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  // Relations
  source    AudienceSource          @relation(fields: [sourceId], references: [id])
  campaigns CommunicationCampaign[]

  @@map("audiences")
}

/// Content type categories for communications
/// Content visibility — controls who can see published content
enum ContentVisibility {
  PUBLIC          // Visible on public blog, no auth required
  CUSTOMER        // Visible only to authenticated customers
  INTERNAL        // Visible only to authenticated staff (Azure AD)
}

enum CommunicationContentType {
  CYBERSECURITY_ALERT
  SERVICE_UPDATE
  MAINTENANCE_NOTICE
  VENDOR_NOTICE
  BEST_PRACTICE
  COMPANY_ANNOUNCEMENT
  GENERAL_COMMUNICATION
}

/// Campaign status workflow
enum CampaignStatus {
  DRAFT
  GENERATING        // AI is generating content
  CONTENT_READY     // Draft generated, awaiting review
  APPROVED          // Content approved, ready to publish
  PUBLISHING        // Publishing blog post
  PUBLISHED         // Blog post live, ready to send email
  SENDING           // Sending email notifications
  SENT              // All emails sent
  FAILED            // Something went wrong
  CANCELLED         // Cancelled by user
}

/// Delivery mode for campaigns
enum DeliveryMode {
  BLOG_AND_EMAIL    // Publish blog post + send notification email (default)
  EMAIL_ONLY        // Send full content via email, no blog post
  BLOG_ONLY         // Publish blog post, no email notifications
}

/// The main campaign entity — a single communication to an audience
model CommunicationCampaign {
  id                String                   @id @default(uuid())
  name              String                   // Campaign name/title
  contentType       CommunicationContentType
  topic             String                   @db.Text // User-provided topic/prompt
  audienceId        String
  visibility        ContentVisibility        @default(PUBLIC)
  deliveryMode      DeliveryMode             @default(BLOG_AND_EMAIL)
  status            CampaignStatus           @default(DRAFT)

  // Content
  generatedTitle    String?
  generatedExcerpt  String?                  @db.Text
  generatedContent  String?                  @db.Text // Markdown content
  generatedMetaTitle       String?
  generatedMetaDescription String?           @db.Text
  generatedKeywords String[]

  // AI metadata
  aiModel           String?
  aiPrompt          String?                  @db.Text

  // Email notification fields
  emailSubject      String?
  emailPreviewText  String?                  @db.Text
  emailBodyHtml     String?                  @db.Text

  // Publishing
  blogPostId        String?                  // Links to BlogPost once published
  publishedAt       DateTime?

  // Email sending
  emailSentAt       DateTime?
  emailTotalCount   Int                      @default(0)
  emailSuccessCount Int                      @default(0)
  emailFailureCount Int                      @default(0)

  // Approval workflow
  approvedAt        DateTime?
  approvedBy        String?                  // Staff email
  rejectionReason   String?                  @db.Text

  // Tracking
  createdBy         String                   // Staff email
  lastModifiedBy    String                   // Staff email
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  // Relations
  audience   Audience             @relation(fields: [audienceId], references: [id])
  recipients CampaignRecipient[]
  auditLogs  CampaignAuditLog[]

  @@map("communication_campaigns")
  @@index([status])
  @@index([createdAt])
  @@index([contentType])
}

/// Snapshot of resolved recipients at send time
model CampaignRecipient {
  id           String   @id @default(uuid())
  campaignId   String
  name         String
  email        String
  companyName  String?
  companyId    String?  // Local company ID if applicable

  // Delivery tracking
  emailStatus  EmailDeliveryStatus @default(PENDING)
  sentAt       DateTime?
  deliveredAt  DateTime?
  openedAt     DateTime?
  failureReason String?            @db.Text

  // Source reference (for audit — which external ID this came from)
  sourceContactId String?          // e.g., Autotask contact ID
  sourceType      AudienceProviderType?

  createdAt    DateTime @default(now())

  // Relations
  campaign CommunicationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_recipients")
  @@index([campaignId])
  @@index([email])
  @@index([emailStatus])
}

enum EmailDeliveryStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  FAILED
  BOUNCED
}

/// Full audit trail for campaign actions
model CampaignAuditLog {
  id          String   @id @default(uuid())
  campaignId  String
  action      String   // "created", "content_generated", "edited", "approved", "published", "email_sent", etc.
  staffEmail  String
  staffName   String?
  details     Json?    // Additional context
  createdAt   DateTime @default(now())

  // Relations
  campaign CommunicationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_audit_logs")
  @@index([campaignId])
  @@index([createdAt])
}

// ============================================
// ERROR LOGGING
// ============================================

/// Automatic error logging for all application errors
model ErrorLog {
  id         String   @id @default(uuid())
  level      String   @default("error") // error, warn, fatal
  source     String   // server, api, client, unhandled
  message    String
  stack      String?
  path       String?  // URL/route where error occurred
  method     String?  // HTTP method (for API errors)
  statusCode Int?     // HTTP status code
  userId     String?  // Staff user email if available
  metadata   Json?    // Additional context
  count      Int      @default(1) // For deduplication
  firstSeen  DateTime @default(now())
  lastSeen   DateTime @default(now())
  resolved   Boolean  @default(false)
  resolvedAt DateTime?
  resolvedBy String?

  @@map("error_logs")
  @@index([source, level])
  @@index([lastSeen])
  @@index([resolved])
  @@index([message])
}

// ============================================
// SOFT DELETE SUPPORT
// ============================================

/// Archive/soft-delete record for reversible deletions
model DeletedRecord {
  id          String   @id @default(uuid())
  entityType  String   // "phase", "project", "comment", "phaseTask"
  entityId    String   // Original record ID
  entityData  Json     // Full snapshot of the deleted record
  relatedData Json?    // Related records (e.g., tasks under a deleted phase)
  deletedBy   String   // Staff email
  deletedAt   DateTime @default(now())
  restoredAt  DateTime?
  restoredBy  String?

  @@map("deleted_records")
  @@index([entityType, entityId])
  @@index([deletedAt])
}

// ============================================
// TEST FAILURE TRACKING
// ============================================

/// Captures e2e test failures with artifacts for AI-assisted debugging
model TestFailure {
  id                  String   @id @default(uuid())
  testName            String
  testFile            String
  url                 String?              // Page URL at time of failure
  environment         String   @default("local") // local, preview, production
  errorMessage        String   @db.Text
  errorStack          String?  @db.Text
  consoleErrors       Json?               // Array of console error strings
  networkErrors       Json?               // Array of failed network requests
  screenshotPath      String?
  tracePath           String?
  commitSha           String?
  branchName          String?
  summary             String?  @db.Text    // AI-generated debugging summary
  rootCauseHypothesis String?  @db.Text    // AI-generated root cause
  suggestedFix        String?  @db.Text    // AI-generated fix suggestion
  impactedFiles       Json?               // Array of likely impacted file paths
  confidence          String?             // high, medium, low
  status              String   @default("open") // open, investigating, fixed, wont_fix
  resolvedAt          DateTime?
  resolvedBy          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("test_failures")
  @@index([status])
  @@index([createdAt])
  @@index([testFile])
}

// ============================================
// REPORTING & ANALYTICS
// ============================================

/// Local cache of Autotask service desk tickets for reporting
model Ticket {
  id                 String    @id @default(uuid())
  autotaskTicketId   String    @unique
  ticketNumber       String
  companyId          String
  title              String
  description        String?   @db.Text
  status             Int                    // Autotask status picklist value
  statusLabel        String?                // Resolved label
  priority           Int                    // Autotask priority picklist value
  priorityLabel      String?                // Resolved label
  queueId            Int?                   // Autotask queue picklist value
  queueLabel         String?
  source             Int?                   // Autotask source picklist value
  sourceLabel        String?
  issueType          Int?
  subIssueType       Int?
  assignedResourceId Int?                   // Primary technician
  creatorResourceId  Int?
  contactId          Int?
  contractId         Int?
  slaId              Int?
  dueDateTime        DateTime?
  estimatedHours     Float?
  createDate         DateTime
  completedDate      DateTime?
  lastActivityDate   DateTime?
  autotaskLastSync   DateTime

  // Relations
  company Company @relation(fields: [companyId], references: [id])

  @@map("tickets")
  @@index([companyId])
  @@index([assignedResourceId])
  @@index([status])
  @@index([createDate])
  @@index([completedDate])
  @@index([queueId])
  @@index([lastActivityDate])
}

/// Ticket notes for first-response-time and communication tracking
model TicketNote {
  id                 String    @id @default(uuid())
  autotaskNoteId     String    @unique
  autotaskTicketId   String
  title              String?
  description        String?   @db.Text
  noteType           Int?
  publish            Int?                   // 1=All, 2=Internal, 3=Customer Portal
  creatorResourceId  Int?                   // Technician
  creatorContactId   Int?                   // Customer
  createDateTime     DateTime

  @@map("ticket_notes")
  @@index([autotaskTicketId])
  @@index([creatorResourceId])
  @@index([createDateTime])
}

/// Time entries on tickets for utilization and consumption tracking
model TicketTimeEntry {
  id                   String    @id @default(uuid())
  autotaskTimeEntryId  String    @unique
  autotaskTicketId     String
  resourceId           Int
  dateWorked           DateTime
  startDateTime        DateTime?
  endDateTime          DateTime?
  hoursWorked          Float
  summaryNotes         String?   @db.Text
  isNonBillable        Boolean   @default(false)
  createDateTime       DateTime?

  @@map("ticket_time_entries")
  @@index([autotaskTicketId])
  @@index([resourceId])
  @@index([dateWorked])
}

/// Autotask technicians / users for reporting attribution
model Resource {
  id                   String    @id @default(uuid())
  autotaskResourceId   Int       @unique
  firstName            String
  lastName             String
  email                String
  isActive             Boolean   @default(true)
  departmentId         Int?
  autotaskLastSync     DateTime

  @@map("resources")
  @@index([email])
}

/// Status transition tracking for tickets (detected by sync diffing)
model TicketStatusHistory {
  id                   String    @id @default(uuid())
  autotaskTicketId     String
  previousStatus       Int?
  newStatus            Int
  previousStatusLabel  String?
  newStatusLabel       String
  changedAt            DateTime
  detectedAt           DateTime  @default(now())

  @@map("ticket_status_history")
  @@index([autotaskTicketId])
  @@index([changedAt])
}

/// Per-ticket computed lifecycle metrics (materialized)
model TicketLifecycle {
  id                       String    @id @default(uuid())
  autotaskTicketId         String    @unique
  companyId                String
  assignedResourceId       Int?
  priority                 Int
  queueId                  Int?
  createDate               DateTime
  completedDate            DateTime?
  isResolved               Boolean   @default(false)

  // Computed metrics
  firstResponseMinutes     Float?
  firstResolutionMinutes   Float?
  fullResolutionMinutes    Float?
  activeResolutionMinutes  Float?
  waitingCustomerMinutes   Float?
  techNoteCount            Int       @default(0)
  customerNoteCount        Int       @default(0)
  reopenCount              Int       @default(0)
  totalHoursLogged         Float     @default(0)
  billableHoursLogged      Float     @default(0)
  isFirstTouchResolution   Boolean   @default(false)
  slaResponseMet           Boolean?
  slaResolutionPlanMet     Boolean?
  slaResolutionMet         Boolean?

  computedAt               DateTime  @default(now())

  @@map("ticket_lifecycle")
  @@index([companyId])
  @@index([assignedResourceId])
  @@index([createDate])
  @@index([isResolved])
  @@index([priority])
}

/// Daily rollup per technician
model TechnicianMetricsDaily {
  id                       String    @id @default(uuid())
  resourceId               Int
  date                     DateTime  @db.Date

  ticketsAssigned          Int       @default(0)
  ticketsCreated           Int       @default(0)
  ticketsClosed            Int       @default(0)
  ticketsReopened          Int       @default(0)

  hoursLogged              Float     @default(0)
  billableHoursLogged      Float     @default(0)
  nonBillableHoursLogged   Float     @default(0)

  avgFirstResponseMinutes  Float?
  avgResolutionMinutes     Float?
  firstTouchResolutions    Int       @default(0)
  totalResolutions         Int       @default(0)

  openTicketCount          Int       @default(0)

  computedAt               DateTime  @default(now())

  @@unique([resourceId, date])
  @@map("technician_metrics_daily")
  @@index([date])
  @@index([resourceId])
}

/// Daily rollup per company
model CompanyMetricsDaily {
  id                           String    @id @default(uuid())
  companyId                    String
  date                         DateTime  @db.Date

  ticketsCreated               Int       @default(0)
  ticketsClosed                Int       @default(0)
  ticketsReopened              Int       @default(0)

  ticketsCreatedUrgent         Int       @default(0)
  ticketsCreatedHigh           Int       @default(0)
  ticketsCreatedMedium         Int       @default(0)
  ticketsCreatedLow            Int       @default(0)

  supportHoursConsumed         Float     @default(0)
  billableHoursConsumed        Float     @default(0)

  avgFirstResponseMinutes      Float?
  avgResolutionMinutes         Float?
  firstTouchResolutionRate     Float?
  reopenRate                   Float?
  slaResponseCompliance        Float?
  slaResolutionCompliance      Float?

  backlogCount                 Int       @default(0)
  backlogUrgent                Int       @default(0)
  backlogHigh                  Int       @default(0)

  computedAt                   DateTime  @default(now())

  @@unique([companyId, date])
  @@map("company_metrics_daily")
  @@index([date])
  @@index([companyId])
}

/// Customer health scores (computed periodically)
model CustomerHealthScore {
  id                       String    @id @default(uuid())
  companyId                String
  computedAt               DateTime  @default(now())
  periodStart              DateTime
  periodEnd                DateTime

  overallScore             Float
  trend                    String              // "improving", "stable", "declining"
  previousScore            Float?

  // Factor scores (0-100 each)
  ticketVolumeTrendScore   Float
  reopenRateScore          Float
  priorityMixScore         Float
  supportHoursTrendScore   Float
  avgResolutionTimeScore   Float
  agingTicketsScore        Float
  slaComplianceScore       Float

  // Raw values for transparency
  ticketCountCurrent       Int
  ticketCountPrevious      Int
  reopenRateValue          Float
  urgentHighPercent        Float
  supportHoursCurrent      Float
  supportHoursPrevious     Float
  avgResolutionMinutes     Float?
  agingTicketCount         Int
  slaCompliancePercent     Float?

  @@map("customer_health_scores")
  @@index([companyId])
  @@index([computedAt])
}

/// Configurable SLA targets and benchmarks
model ReportingTarget {
  id                 String    @id @default(uuid())
  metricKey          String              // "first_response_time", "resolution_time", etc.
  scope              String    @default("global") // "global", "priority", "company"
  scopeValue         String    @default("") // e.g., "URGENT", company UUID; empty = global
  targetValue        Float
  unit               String              // "minutes", "percent", "hours", "count"
  description        String?
  isActive           Boolean   @default(true)
  createdBy          String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([metricKey, scope, scopeValue])
  @@map("reporting_targets")
}

/// Scheduled report definitions
model ReportSchedule {
  id                 String    @id @default(uuid())
  reportType         String              // "technician_weekly", "company_monthly", etc.
  name               String
  schedule           String              // "weekly", "monthly", "quarterly"
  dayOfWeek          Int?                // 0=Sun..6=Sat (for weekly)
  dayOfMonth         Int?                // 1-28 (for monthly)
  monthOfQuarter     Int?                // 1-3 (for quarterly)
  recipients         String[]
  config             Json?               // Report-specific filters
  isActive           Boolean   @default(true)
  nextRunAt          DateTime
  lastRunAt          DateTime?
  lastRunStatus      String?             // "success", "failed"
  createdBy          String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("report_schedules")
  @@index([nextRunAt])
  @@index([isActive])
}

/// Delivery log for sent reports
model ReportDeliveryLog {
  id                 String    @id @default(uuid())
  scheduleId         String
  reportType         String
  periodStart        DateTime
  periodEnd          DateTime
  recipientCount     Int
  status             String              // "sent", "failed", "partial"
  error              String?   @db.Text
  sentAt             DateTime  @default(now())

  @@map("report_delivery_logs")
  @@index([scheduleId])
  @@index([sentAt])
}

/// Business review reports (monthly/quarterly, customer-facing and internal)
model BusinessReview {
  id                 String    @id @default(uuid())
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id])
  reportType         String              // "monthly", "quarterly"
  variant            String   @default("customer")  // "customer", "internal"
  periodStart        DateTime
  periodEnd          DateTime
  status             String   @default("draft")     // "draft", "review", "ready", "sent"
  reportData         Json                // Full structured report payload
  recommendations    Json?               // Structured recommendations array
  narrative          Json?               // Generated narrative sections
  createdBy          String
  reviewedBy         String?
  reviewedAt         DateTime?
  sentAt             DateTime?
  sentTo             String[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("business_reviews")
  @@index([companyId])
  @@index([status])
  @@index([periodStart])
  @@unique([companyId, reportType, variant, periodStart])
}

/// Tracks last run time for each reporting job
model ReportingJobStatus {
  id                 String    @id @default(uuid())
  jobName            String    @unique    // "sync_tickets", "compute_lifecycle", etc.
  lastRunAt          DateTime?
  lastRunStatus      String?             // "success", "failed"
  lastRunDurationMs  Int?
  lastRunError       String?   @db.Text
  lastRunMeta        Json?               // Job-specific metadata (counts, etc.)
  updatedAt          DateTime  @updatedAt

  @@map("reporting_job_status")
}

