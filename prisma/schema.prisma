// ============================================
// PTO / TIME-OFF SYSTEM
// ============================================
// Gusto is the source of truth for balances and policies.
// Our DB owns the request + approval workflow.
// Microsoft 365 shared calendar displays approved absences.

// Singleton-ish connection record for the TCT Gusto account.
// Only one active connection at a time (enforced at application layer).
model GustoConnection {
  id                String    @id @default(uuid())
  environment       String    // "demo" | "production"
  companyUuid       String?   // Gusto company UUID (resolved after first API call)
  companyName       String?   // Human-readable Gusto company name
  accessToken       String    @db.Text
  refreshToken      String    @db.Text
  tokenExpiresAt    DateTime
  scope             String?   @db.Text
  connectedByEmail  String
  connectedAt       DateTime  @default(now())
  lastRefreshedAt   DateTime?
  lastSyncAt        DateTime?
  lastSyncStatus    String?   // "ok" | "error"
  lastSyncError     String?   @db.Text
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("gusto_connections")
  @@index([isActive])
}

// Links a StaffUser to their Gusto employee record.
// Populated via auto-match-by-email + admin override.
model PtoEmployeeMapping {
  id                   String    @id @default(uuid())
  staffUserId          String    @unique
  staffEmail           String    // denormalized for search
  gustoEmployeeUuid    String    @unique
  gustoWorkEmail       String?
  gustoPersonalEmail   String?
  gustoFirstName       String?
  gustoLastName        String?
  matchMethod          String    // "auto_email" | "manual" | "auto_name"
  mappedByStaffId      String?
  lastGustoSyncAt      DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  timeOffRequests TimeOffRequest[]

  @@map("pto_employee_mappings")
  @@index([staffEmail])
  @@index([gustoEmployeeUuid])
}

enum TimeOffRequestStatus {
  PENDING           // legacy — migrated to PENDING_INTAKE
  PENDING_INTAKE    // waiting for HR intake (e.g. Rio) to gather context
  PENDING_APPROVAL  // waiting for final approver (e.g. Kurtis)
  APPROVED
  DENIED
  CANCELLED
}

enum TimeOffRequestKind {
  VACATION
  SICK
  PERSONAL
  BEREAVEMENT
  JURY_DUTY
  UNPAID
  OTHER
}

model TimeOffRequest {
  id                  String               @id @default(uuid())
  mappingId           String?              // optional — kept for future Gusto re-wiring
  employeeStaffId     String               // StaffUser.id of requester
  employeeEmail       String
  employeeName        String
  gustoEmployeeUuid   String?              // optional — future Gusto sync
  kind                TimeOffRequestKind   @default(VACATION)
  gustoPolicyUuid     String?              // future Gusto sync
  gustoPolicyName     String?
  startDate           DateTime             @db.Date
  endDate             DateTime             @db.Date
  // For partial days: map of YYYY-MM-DD => hours. Null/missing = full day (8h)
  hoursPerDay         Json?                @default("{}")
  totalHours          Decimal              @db.Decimal(7, 2)
  notes               String?              @db.Text
  coverage            String?              @db.Text  // free-form notes (legacy / fallback)

  // Coverage approval (new): employee picks a covering teammate, they
  // receive an email and accept/decline; HR sees the response before approving.
  coverageStaffId       String?
  coverageStaffName     String?
  coverageStaffEmail    String?
  coverageResponse      String?   // 'pending' | 'accepted' | 'declined' | null (not requested)
  coverageRespondedAt   DateTime?
  coverageResponseNotes String?   @db.Text
  coverageToken         String?   @unique  // opaque signed token for accept/decline URL
  coverageRequestSentAt DateTime?

  status              TimeOffRequestStatus @default(PENDING_INTAKE)

  // HR intake (stage 1) — e.g. Rio fills this in, then forwards to final approver
  intakeByStaffId         String?
  intakeByName            String?
  intakeAt                DateTime?
  intakeLastTimeOffNotes  String?          @db.Text  // previous time-off context
  intakeBalanceNotes      String?          @db.Text  // current PTO balance as pulled from Gusto manually
  intakeCoverageConfirmed Boolean?                    // did Rio verify coverage?
  intakeCoverageNotes     String?          @db.Text
  intakeAdditionalNotes   String?          @db.Text
  intakeSkipped           Boolean          @default(false)  // true when final approver bypassed intake

  // Review / final approval (stage 2) details
  reviewedByStaffId   String?
  reviewedByName      String?
  reviewedAt          DateTime?
  managerNotes        String?              @db.Text

  // Post-approval: manual confirmation that HR has entered the PTO into Gusto
  gustoRecordedAt           DateTime?
  gustoRecordedByStaffId    String?
  gustoRecordedByName       String?

  // Gusto sync (currently unused — reserved for when Gusto API access opens)
  gustoBalanceAdjustmentAt DateTime?
  gustoSyncStatus     String?              // "pending" | "ok" | "error" | "skipped"
  gustoSyncError      String?              @db.Text
  gustoSyncAttempts   Int                  @default(0)

  // Calendar sync
  graphEventId        String?              // event id on the shared PTO calendar
  graphInviteEventId  String?              // event id on the employee's calendar (invite)
  graphSyncStatus     String?              // "pending" | "ok" | "error"
  graphSyncError      String?              @db.Text
  graphSyncAttempts   Int                  @default(0)

  // Notification tracking
  submitterNotifiedAt  DateTime?
  intakeNotifiedAt     DateTime?   // intake assignees notified (stage 1)
  approversNotifiedAt  DateTime?   // final approvers notified (stage 2)
  employeeNotifiedAt   DateTime?

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  mapping    PtoEmployeeMapping? @relation(fields: [mappingId], references: [id], onDelete: SetNull)
  auditLogs  TimeOffAuditLog[]

  @@map("time_off_requests")
  @@index([employeeStaffId, status])
  @@index([status, startDate])
  @@index([startDate, endDate])
}

model TimeOffAuditLog {
  id           String   @id @default(uuid())
  requestId    String
  actorStaffId String?
  actorEmail   String
  actorName    String?
  action       String   // "submitted" | "approved" | "denied" | "cancelled" | "gusto_sync" | "calendar_sync" | "retry"
  details      Json?
  severity     String   @default("info")
  createdAt    DateTime @default(now())

  request TimeOffRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("time_off_audit_logs")
  @@index([requestId, createdAt(sort: Desc)])
}
